# ──────────────────────────────────────────────
# Harmonic Waves Command Centre — Environment
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.

# Weather (OpenWeatherMap — free tier: 1000 calls/day)
# Get a key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here
WEATHER_LAT=51.5074
WEATHER_LON=-0.1278

# Tidal provider: "noaa" (default, free, keyless) or "admiralty" (UK data, free tier)
TIDAL_PROVIDER=noaa

# NOAA Tides (default — free, no key needed)
# Station list: https://tidesandcurrents.noaa.gov/stations.html
NOAA_TIDAL_STATION=8518750

# UK Admiralty Tidal API (optional — for real UK/Thames data)
# Register free at https://admiraltyapi.portal.azure-api.net
# TIDAL_PROVIDER=admiralty
# ADMIRALTY_API_KEY=your_key_here
# TIDAL_STATION_ID=0113
